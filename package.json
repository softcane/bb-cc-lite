{
  "name": "ccverdict",
  "version": "0.4.2",
  "description": "ccverdict: a small Claude Code status line that says when to continue, slow down, or stop.",
  "type": "module",
  "author": "Softcane",
  "homepage": "https://github.com/softcane/ccverdict#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/softcane/ccverdict.git"
  },
  "bugs": {
    "url": "https://github.com/softcane/ccverdict/issues"
  },
  "bin": {
    "ccverdict": "dist/cli.js"
  },
  "files": [
    "assets",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/cli.js',0o755)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "behavior-gauge",
    "verdict",
    "claude-code",
    "claude",
    "statusline",
    "litellm",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "25.9.0",
    "eslint": "9.39.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.4",
    "vitest": "4.1.6"
  }
}
